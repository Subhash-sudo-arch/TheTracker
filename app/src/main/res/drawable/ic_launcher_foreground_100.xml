<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Subtle background shadow gradient effect -->
    <path
        android:fillColor="#15000000"
        android:pathData="M 32 32 L 80 80 L 80 32 Z" />

    <!-- Unfilled background progress track ring (Gray) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#4A4A5A"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:pathData="M 54 20 A 34 34 0 1 1 53.99 20" />

    <!-- 100% Active Progress Ring -->
    <path
        android:fillColor="#00000000"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:trimPathEnd="1.00"
        android:pathData="M 54 20 A 34 34 0 1 1 53.99 20">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="20"
                android:startY="20"
                android:endX="88"
                android:endY="88"
                android:type="linear">
                <item android:color="#8B5CF6" android:offset="0.0"/>
                <item android:color="#3B82F6" android:offset="0.2"/>
                <item android:color="#10B981" android:offset="0.4"/>
                <item android:color="#F59E0B" android:offset="0.6"/>
                <item android:color="#EF4444" android:offset="0.8"/>
                <item android:color="#EC4899" android:offset="1.0"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Center Check Mark (✓) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M 38 54 L 48 64 L 70 42" />
</vector>
