<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_dark"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- Left Side: Progress & Streak -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.3"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingEnd="8dp">

        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginBottom="4dp">

            <ProgressBar
                android:id="@+id/widget_progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/widget_progress_circle" />

            <TextView
                android:id="@+id/widget_progress_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="0%"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/widget_streak_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 0 DAYS"
            android:textColor="#FF9800"
            android:textStyle="bold"
            android:textSize="10sp"
            android:letterSpacing="0.05" />
    </LinearLayout>

    <!-- Divider line -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#252535"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp" />

    <!-- Right Side: Four Quick Actions (2x2 Grid) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2.7"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="8dp">

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/btn_sleep"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/widget_btn_inactive"
                android:gravity="center"
                android:text="🌙 Sleep"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_study"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/widget_btn_inactive"
                android:gravity="center"
                android:text="📚 Study"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_workout"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/widget_btn_inactive"
                android:gravity="center"
                android:text="🏋 Workout"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_productivity"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/widget_btn_inactive"
                android:gravity="center"
                android:text="💼 Work"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
